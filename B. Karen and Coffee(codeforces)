n , k , q = map(int , input().split())

limit = 200000
arr = [0] * (limit + 2)

for _ in range(n):
    left ,right =  map(int , input().split())
    arr[left] += 1
    arr[right + 1] -= 1

for i in range(1,limit+1):
    arr[i] += arr[i-1]

good = [0] * (limit + 2)
for i in range(1,limit+1):
    if arr[i] >= k:
        good[i] = 1

for i in range(1,limit+1):
    good[i] += good[i-1]

for _ in range(q):
    left ,right =  map(int , input().split())
    print(good[right] - good[left -1])














 

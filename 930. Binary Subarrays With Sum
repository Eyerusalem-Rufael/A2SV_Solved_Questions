class Solution:
    def numSubarraysWithSum(self, nums: List[int], goal: int) -> int:
        curr_sum = 0
        sum_dict = defaultdict(int)
        sum_dict[0] = 1
        count = 0

        for num in nums:
            curr_sum += num
            count += sum_dict[curr_sum - goal]
            sum_dict[curr_sum] += 1

        return count
